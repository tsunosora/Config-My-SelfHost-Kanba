# =============================================
# KANBA - Environment Variables Template
# Salin file ini ke .env.local dan isi nilainya
# cp .env.local.example .env.local
# =============================================

# Database provider
DATABASE_PROVIDER=postgresql

# Supabase - dapatkan dari Supabase dashboard atau self-hosted instance
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database URL - gunakan hostname container jika di Docker, localhost jika PM2
# Contoh PM2/host langsung: postgresql://postgres:password@localhost:5433/postgres
# Contoh Docker container:  postgresql://postgres:password@supabase-db:5432/postgres
DATABASE_URL=postgresql://postgres:your-db-password@localhost:5433/postgres
DIRECT_URL=postgresql://postgres:your-db-password@localhost:5433/postgres

# URL aplikasi - ganti dengan IP/domain server kamu
NEXT_PUBLIC_SITE_URL=http://YOUR_SERVER_IP:3000
NEXTAUTH_URL=http://YOUR_SERVER_IP:3000

# Secret acak untuk NextAuth - generate dengan: openssl rand -hex 32
NEXTAUTH_SECRET=your-random-secret-here
